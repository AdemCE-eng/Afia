PORT=3000

# Optional: used by /api/generate-plan and /api/patient-chat.
GEMINI_API_KEY=

# Required for the watsonx Orchestrate embedded chat token endpoint.
# Upload the matching public key in watsonx Orchestrate, then put the private key here.
# Use either WXO_JWT_PRIVATE_KEY with escaped newlines or WXO_JWT_PRIVATE_KEY_PATH.
WXO_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
WXO_JWT_PRIVATE_KEY_PATH=
WXO_JWT_KEY_ID=
WXO_JWT_EXPIRES_IN=1h

# Optional but recommended for IBM secure embed. Generate this in:
# watsonx Orchestrate > Settings > Embed Security > Encrypt sensitive information.
WXO_IBM_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
WXO_IBM_PUBLIC_KEY_PATH=

# If the static frontend is hosted on GitHub Pages and the backend elsewhere,
# set this to the GitHub Pages origin, for example:
# CORS_ORIGIN=https://ademce-eng.github.io
CORS_ORIGIN=
